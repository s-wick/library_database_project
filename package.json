{
  "name": "library-database-root",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "user-tabs": "node scripts/open-user-tabs.js",
    "db:dump": "node scripts/dump-database.js",
    "db:reset": "node scripts/reset-database.js",
    "db:update-dates": "node scripts/update-sample-dates.js",
    "format": "prettier --write .",
    "lint": "npm run lint --prefix frontend && npm run lint --prefix backend"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint && npm run format"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "playwright": "^1.56.1",
    "simple-git-hooks": "^2.13.1"
  }
}
